{
  "name": "xifan-coder",
  "version": "1.0.4",
  "description": "XiFanCoder - AI Agent CLI Coding Tool",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "prepare": "husky",
    "postinstall": "node 02_scripts/postinstall-prompt.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:integration": "pnpm -r --if-present run test:integration",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "test:whitebox": "node 02_scripts/run-whitebox-integration-tests.mjs",
    "test:blackbox": "node 02_scripts/run-blackbox-user-tests.mjs",
    "test:blackbox:ui": "bash 02_scripts/run-blackbox-ui-tests.sh",
    "test:integration:prd": "node 02_scripts/run-integration-prd-tests.mjs",
    "test:release-gate": "pnpm run test:whitebox && pnpm run test:blackbox && pnpm run test:blackbox:ui",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "docs:check": "node 02_scripts/check-docs-governance.mjs",
    "plugin:check": "node 02_scripts/check-plugin-publish-governance.mjs",
    "npm:leak-check": "node 02_scripts/check-npm-package-leaks.mjs",
    "env:check": "bash 02_scripts/check-runtime-env.sh",
    "version:check": "node 02_scripts/version-lockstep.mjs check",
    "version:bump": "node 02_scripts/version-lockstep.mjs bump",
    "release:notes": "node 02_scripts/generate-release-notes.mjs",
    "update:feed:generate": "node 02_scripts/generate-update-feed-payload.mjs",
    "update:feed:publish": "bash 02_scripts/publish-update-feed-pr.sh",
    "sprint:report": "node 02_scripts/gh-sprint-report.mjs",
    "governance:public:apply": "bash 02_scripts/github-governance/apply-public-repo-governance.sh --target all",
    "governance:public:verify": "bash 02_scripts/github-governance/apply-public-repo-governance.sh --target all --mode verify",
    "docs:site:dev": "vitepress dev docs-site --host 0.0.0.0 --port 4173",
    "docs:site:build": "vitepress build docs-site",
    "docs:site:preview": "vitepress preview docs-site --host 0.0.0.0 --port 4173",
    "perf:context-bench": "node 02_scripts/benchmark-context-compression.mjs",
    "gh:status": "bash 02_scripts/gh-project-status.sh",
    "setup:client": "bash 02_scripts/setup-client.sh",
    "publish:npm": "bash 02_scripts/publish-npm.sh",
    "publish:npm:dry": "bash 02_scripts/publish-npm.sh --dry-run"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.3",
      "archiver-utils>lodash": "4.18.0",
      "esbuild": "^0.27.3",
      "rollup": "^4.59.0",
      "undici": "^6.24.0",
      "flatted": "^3.4.2",
      "picomatch": "^4.0.4",
      "brace-expansion": "^5.0.5",
      "hono": "^4.12.12",
      "@hono/node-server": "^1.19.13",
      "express-rate-limit": "^8.2.2",
      "path-to-regexp": "^8.4.0",
      "vite": "^6.4.2"
    }
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.1",
    "typescript": "^5.5.0",
    "vitepress": "^1.6.4"
  }
}
